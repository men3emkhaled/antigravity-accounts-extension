{
  "name": "agent-assistant",
  "displayName": "Agent Assistant",
  "description": "The definitive Expert Persona & Quota Management system for AI Agents. Empower your workflow with deep skill injection and real-time resource tracking.",
  "version": "1.0.1",
  "icon": "logo2.png",
  "publisher": "men3em",
  "repository": {
    "type": "git",
    "url": "https://github.com/men3emkhaled/agent-assistant-extension.git"
  },
  "bugs": {
    "url": "https://github.com/men3emkhaled/agent-assistant-extension/issues"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "men3em",
    "agent-assistant",
    "antigravity hub",
    "antigravity model balance",
    "antigravity balance",
    "antigravity ai",
    "antigravity google-ai",
    "antigravity credits",
    "account-manager",
    "google-ai",
    "credits",
    "multi-account"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "agent-assistant.openPanel",
        "title": "Open Agent Assistant Dashboard",
        "category": "Agent Assistant"
      },
      {
        "command": "agent-assistant.refreshAccounts",
        "title": "Refresh Accounts",
        "icon": "$(refresh)"
      },
      {
        "command": "agent-assistant.addAccount",
        "title": "Add Account",
        "icon": "$(add)"
      },
      {
        "command": "agent-assistant.searchAccounts",
        "title": "Search Accounts",
        "icon": "$(search)"
      },
      {
        "command": "agent-assistant.clearSearch",
        "title": "Clear Search",
        "icon": "$(close)"
      },
      {
        "command": "agent-assistant.treeDelete",
        "title": "Remove Account",
        "category": "Agent Assistant",
        "icon": "$(trash)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agent-assistant",
          "title": "Agent Assistant",
          "icon": "resources/icons/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "agent-assistant": [
        {
          "id": "agent-assistant.accountsView",
          "name": "Accounts",
          "icon": "resources/icons/sidebar-icon.svg"
        },
        {
          "id": "agent-assistant.skillsView",
          "name": "Expert Skills",
          "icon": "resources/icons/sidebar-icon.svg"
        }
      ]
    },
    "menus": {
      "view/item/context": [
        {
          "command": "agent-assistant.treeSwitch",
          "when": "viewItem == inactiveAccount",
          "group": "inline"
        },
        {
          "command": "agent-assistant.treeDelete",
          "when": "viewItem == activeAccount || viewItem == inactiveAccount",
          "group": "inline"
        }
      ],
      "view/title": [
        {
          "command": "agent-assistant.searchAccounts",
          "when": "view == agent-assistant.accountsView",
          "group": "navigation"
        },
        {
          "command": "agent-assistant.clearSearch",
          "when": "view == agent-assistant.accountsView && agent-assistant.isSearching",
          "group": "navigation"
        },
        {
          "command": "agent-assistant.refreshAccounts",
          "when": "view == agent-assistant.accountsView",
          "group": "navigation"
        },
        {
          "command": "agent-assistant.addAccount",
          "when": "view == agent-assistant.accountsView",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "agent-assistant.openPanel",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      },
      {
        "command": "agent-assistant.switchAccount",
        "key": "ctrl+shift+s",
        "mac": "cmd+shift+s"
      },
      {
        "command": "agent-assistant.addAccount",
        "key": "ctrl+shift+n",
        "mac": "cmd+shift+n"
      },
      {
        "command": "agent-assistant.refreshBalances",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r"
      }
    ],
    "configuration": {
      "title": "Agent Assistant",
      "properties": {
        "antigravityAccounts.language": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "en",
            "ar"
          ],
          "enumDescriptions": [
            "Auto (Detect from Editor)",
            "English",
            "العربية"
          ],
          "description": "Display language for the extension UI"
        },
        "antigravityAccounts.refreshIntervalMinutes": {
          "type": "number",
          "default": 15,
          "minimum": 1,
          "maximum": 120,
          "description": "Interval in minutes for automatic balance refresh"
        },
        "antigravityAccounts.lowCreditThreshold": {
          "type": "number",
          "default": 100,
          "minimum": 10,
          "description": "Credit threshold for low balance warning"
        },
        "antigravityAccounts.enableAutoSwitch": {
          "type": "boolean",
          "default": false,
          "description": "Automatically switch to another account when the active account's credit is depleted"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --external:sql.js --format=cjs --platform=node --minify",
    "watch": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --external:sql.js --format=cjs --platform=node --sourcemap --watch",
    "compile": "tsc -p ./",
    "lint": "eslint src --ext ts",
    "package": "npx -y @vscode/vsce package",
    "package:win": "npx -y @vscode/vsce package --target win32-x64",
    "package:mac": "npx -y @vscode/vsce package --target darwin-arm64 --target darwin-x64",
    "package:linux": "npx -y @vscode/vsce package --target linux-x64",
    "package:all": "npm run package:win && npm run package:mac && npm run package:linux"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "sql.js": "^1.14.1"
  }
}