{
  "name": "antigravity-accounts",
  "displayName": "Antigravity Accounts",
  "description": "Advanced account synchronization and quota management for the Antigravity desktop environment. Optimizes multi-session workflows with secure credential handling and automated rotation.",
  "version": "1.0.0",
  "publisher": "men3em",
  "repository": {
    "type": "git",
    "url": "https://github.com/men3emkhaled/antigravity-accounts-extension.git"
  },
  "bugs": {
    "url": "https://github.com/men3emkhaled/antigravity-accounts-extension/issues"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "men3em",
    "antigravity",
    "antigravity hub",
    "antigravity account-manager",
    "antigravity multi-account",
    "antigravity accounts",
    "antigravity credits",
    "antigravity tokens",
    "antigravity model",
    "antigravity model balance",
    "antigravity balance",
    "antigravity ai",
    "antigravity google-ai",
    "antigravity credits",
    "account-manager",
    "google-ai",
    "credits",
    "multi-account"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "icon": "resources/icons/logo.png",
  "contributes": {
    "commands": [
      {
        "command": "antigravity-accounts.openPanel",
        "title": "Open Account Manager",
        "category": "Antigravity Accounts"
      },
      {
        "command": "antigravity-accounts.addAccount",
        "title": "Add Account",
        "category": "Antigravity Accounts",
        "icon": "$(add)"
      },
      {
        "command": "antigravity-accounts.switchAccount",
        "title": "Switch Account",
        "category": "Antigravity Accounts"
      },
      {
        "command": "antigravity-accounts.searchAccounts",
        "title": "Search Accounts",
        "icon": "$(search)"
      },
      {
        "command": "antigravity-accounts.clearSearch",
        "title": "Clear Search",
        "icon": "$(close)"
      },
      {
        "command": "antigravity-accounts.refreshAccounts",
        "title": "Refresh All",
        "icon": "$(refresh)"
      },
      {
        "command": "antigravity-accounts.refreshBalances",
        "title": "Refresh All Balances",
        "category": "Antigravity Accounts",
        "icon": "$(refresh)"
      },
      {
        "command": "antigravity-accounts.setLanguage",
        "title": "Set Language",
        "category": "Antigravity Accounts"
      },
      {
        "command": "antigravity-accounts.treeSwitch",
        "title": "Switch",
        "category": "Antigravity Accounts",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "antigravity-accounts.treeDelete",
        "title": "Remove Account",
        "category": "Antigravity Accounts",
        "icon": "$(trash)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "antigravity-accounts",
          "title": "Antigravity Accounts",
          "icon": "resources/icons/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "antigravity-accounts": [
        {
          "id": "antigravity-accounts.accountsView",
          "name": "Accounts",
          "icon": "resources/icons/sidebar-icon.svg"
        }
      ]
    },
    "menus": {
      "view/item/context": [
        {
          "command": "antigravity-accounts.treeSwitch",
          "when": "viewItem == inactiveAccount",
          "group": "inline"
        },
        {
          "command": "antigravity-accounts.treeDelete",
          "when": "viewItem == activeAccount || viewItem == inactiveAccount",
          "group": "inline"
        }
      ],
      "view/title": [
        {
          "command": "antigravity-accounts.searchAccounts",
          "when": "view == antigravity-accounts.accountsView",
          "group": "navigation"
        },
        {
          "command": "antigravity-accounts.clearSearch",
          "when": "view == antigravity-accounts.accountsView && antigravity-accounts.isSearching",
          "group": "navigation"
        },
        {
          "command": "antigravity-accounts.refreshAccounts",
          "when": "view == antigravity-accounts.accountsView",
          "group": "navigation"
        },
        {
          "command": "antigravity-accounts.addAccount",
          "when": "view == antigravity-accounts.accountsView",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "antigravity-accounts.openPanel",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      },
      {
        "command": "antigravity-accounts.switchAccount",
        "key": "ctrl+shift+s",
        "mac": "cmd+shift+s"
      },
      {
        "command": "antigravity-accounts.addAccount",
        "key": "ctrl+shift+n",
        "mac": "cmd+shift+n"
      },
      {
        "command": "antigravity-accounts.refreshBalances",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r"
      }
    ],
    "configuration": {
      "title": "Antigravity Accounts",
      "properties": {
        "antigravityAccounts.language": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "en",
            "ar"
          ],
          "enumDescriptions": [
            "Auto (Detect from Editor)",
            "English",
            "العربية"
          ],
          "description": "Display language for the extension UI"
        },
        "antigravityAccounts.refreshIntervalMinutes": {
          "type": "number",
          "default": 15,
          "minimum": 1,
          "maximum": 120,
          "description": "Interval in minutes for automatic balance refresh"
        },
        "antigravityAccounts.lowCreditThreshold": {
          "type": "number",
          "default": 100,
          "minimum": 10,
          "description": "Credit threshold for low balance warning"
        },
        "antigravityAccounts.enableAutoSwitch": {
          "type": "boolean",
          "default": false,
          "description": "Automatically switch to another account when the active account's credit is depleted"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --external:sql.js --format=cjs --platform=node --minify",
    "watch": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --external:sql.js --format=cjs --platform=node --sourcemap --watch",
    "compile": "tsc -p ./",
    "lint": "eslint src --ext ts",
    "package": "npx -y @vscode/vsce package",
    "package:win": "npx -y @vscode/vsce package --target win32-x64",
    "package:mac": "npx -y @vscode/vsce package --target darwin-arm64 --target darwin-x64",
    "package:linux": "npx -y @vscode/vsce package --target linux-x64",
    "package:all": "npm run package:win && npm run package:mac && npm run package:linux"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "sql.js": "^1.14.1"
  }
}
